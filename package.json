{
  "name": "golf-tier-game",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "vite",
    "deploy": "npm run build && wrangler deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "wrangler types && react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.18.0",
    "@react-router/node": "7.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.1",
    "isbot": "^5"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.1",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.1.0",
    "wrangler": "4.110.0"
  }
}
